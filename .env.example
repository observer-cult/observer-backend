# Database
DATABASE_URL="postgresql://user:password@localhost:5432/observer_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="7d"
REFRESH_TOKEN_EXPIRY="30d"

# Ethereum
ETHEREUM_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/your-api-key"
OBS_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# External APIs
COINGECKO_API_KEY="your-coingecko-api-key"

# Server
PORT=3000
NODE_ENV="development"

# Tier thresholds (in wei)
TIER_0_THRESHOLD="0"
TIER_1_THRESHOLD="1000000000000000000"
TIER_2_THRESHOLD="10000000000000000000"
TIER_3_THRESHOLD="100000000000000000000"
TIER_4_THRESHOLD="1000000000000000000000"

# Rate limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"
