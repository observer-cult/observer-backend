    "axios": "^1.6.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "typescript-eslint": "^6.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/jsonwebtoken": "^9.0.0"
